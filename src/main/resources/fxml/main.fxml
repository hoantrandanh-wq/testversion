<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.app.controller.MainController"
      spacing="20" alignment="CENTER"
      prefWidth="600" prefHeight="300">

    <Label text="Nhấn nút để gọi Spring Service:" />
    <Button text="Say Hello" onAction="#onButtonClick" />
    <Label fx:id="labelResult" text="" style="-fx-font-size: 16px; -fx-font-weight: bold;" />

    <Separator />

    <!-- Phần update -->
    <Label text="Kiểm tra cập nhật:" />
    <Button fx:id="btnCheckUpdate" text="🔄 Kiểm tra phiên bản mới"
            onAction="#onCheckUpdateManual" />
    <Label fx:id="labelUpdateStatus" text=""
           style="-fx-text-fill: gray;" />

</VBox>